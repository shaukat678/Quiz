# React Context API Debugging Challenge

## Codebase

```jsx
import React, {
  createContext,
  useContext,
  useState,
  useEffect
} from "react";

// Context
const UserContext = createContext();

function Header() {
  const { user } = useContext(UserContext);

  return (
    <div>
      <h2>Welcome {user.name}</h2>
    </div>
  );
}

function Profile() {
  const { user, setUser } = useContext(UserContext);

  function updateName() {
    user.name = "Ahmed";

    setUser(user);
  }

  return (
    <div>
      <h3>Name: {user.name}</h3>

      <button onClick={updateName}>
        Change Name
      </button>
    </div>
  );
}

function Dashboard() {
  const { theme } = useContext(UserContext);

  return (
    <div>
      <h3>Theme: {theme}</h3>
    </div>
  );
}

function Settings() {
  const { theme, setTheme } =
    useContext(UserContext);

  return (
    <button
      onClick={() =>
        setTheme(
          theme === "light"
            ? "dark"
            : "light"
        )
      }
    >
      Toggle Theme
    </button>
  );
}

export default function App() {
  const [user, setUser] = useState({
    id: 1,
    name: "Ali"
  });

  const [theme, setTheme] =
    useState("light");

  useEffect(() => {
    console.log("App Mounted");
  }, []);

  const value = {
    user,
    setUser,
    theme,
    setTheme
  };

  return (
    <UserContext.Provider value={value}>
      <Header />

      <Profile />

      <Dashboard />

      <Settings />
    </UserContext.Provider>
  );
}
```

